;; .define NUM_PINS SCS_PIN - CTS_PIN + 1

;; .wrap_target
;; idle:
;; 	irq IRQ_SEL		; Signal that we're selected
;; 	mov osr, ~pins		; read in all pins inverted

;; 	;out null, CTS_PIN	; dump lower bits
;; 	out x, NUM_PINS		; grab the two /CTS /SCS bits we want
