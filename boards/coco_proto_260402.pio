.pio_version 1

;; this file will get prepended to bus.pio

.define public DATA_WIDTH	8
.define public ADDR_WIDTH	16

.define public A0_PIN		0	; A0..A15 are consecutive
.define public D0_PIN		20	; D0..D7 are consecutive
.define public RW_PIN		29	; 6809 R/W signal
;; .define public SCS_PIN		30	; Cartridge IO select
;; .define public CTS_PIN		32	; Cartridge ROM select
.define public SCS_PIN		17	; Cartridge IO select
.define public CTS_PIN		16	; Cartridge ROM select
;; .define public CLOCK_PIN	33	; 6809 clock E signal
.define public CLOCK_PIN	18	; 6809 clock E signal
.define public RESET_PIN	35	; RESET

.define public PIN_COUNT 32

.define public IRQ_SEL 0

.program decode_addrdata
% c-sdk {
typedef union {
  struct {
    uint32_t addr:ADDR_WIDTH;
    uint32_t cts:1;
    uint32_t scs:1;
    uint32_t clock:1;
    uint32_t resv:1;
    uint32_t data:DATA_WIDTH;
    uint32_t resv2:1;
    uint32_t rw:1;
  } __attribute__((packed));
  uint32_t combined;
} __attribute__((packed)) BusSignals;
%}

